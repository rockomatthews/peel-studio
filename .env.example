# Public app URL, without a trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI image generation (never put a real key in this tracked template)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high

# Vercel Blob and Neon Postgres
BLOB_READ_WRITE_TOKEN=
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Printify server-side personal access token (Bearer token; never expose to the browser)
PRINTIFY_API_TOKEN=
# Numeric ID of the API-connected Printify store that will receive orders
PRINTIFY_SHOP_ID=
# Numeric catalog ID for the base sticker product
PRINTIFY_BLUEPRINT_ID=600
# Numeric manufacturer/fulfillment provider ID for that blueprint
PRINTIFY_PRINT_PROVIDER_ID=73
# Comma-separated variant IDs customers may choose (size/finish/material SKUs)
PRINTIFY_VARIANT_IDS=72007
# Printify placeholder position to use when reading each variant's exact pixel canvas
PRINTIFY_PRINT_AREA=front
# Optional: disambiguates placeholders that share a position but use different print methods
PRINTIFY_DECORATION_METHOD=uv
# 1 standard, 2 priority, 3 Printify Express. Start with standard.
PRINTIFY_SHIPPING_METHOD=1
# Fraction of every canvas protected from edge clipping; 0.08 means 8% per side
PRINT_SAFE_MARGIN=0.08

# Set true only after a successful test order. This causes real Printify charges.
PRINTIFY_AUTO_SEND_TO_PRODUCTION=false

# Secret appended to the Printify webhook URL
PRINTIFY_WEBHOOK_SECRET=

# Comma-separated ISO country codes supported by the selected Printify provider
SHIPPING_COUNTRIES=US
